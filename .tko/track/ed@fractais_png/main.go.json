            "content": "package main\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n)\n\nfunc randInt(inf, sup int) float64 {\n\treturn float64(rand.Intn(sup-inf+1) + inf)\n}\n\n/* func arvore(pen *Pen, dist float64) {\n\tif dist < 20 {\n\t\treturn\n\t}\t\n\t\n\tpen.SetLineWidth(dist / 8)\n\tpen.Walk(dist)\n\tpen.Right(20)\n\tcirculo(pen, dist * 0.8)\n\tpen.Right(-2 * 20)\n\tcirculo(pen, dist * 0.8)\n\tpen.Right(20)\n\tpen.Walk(-dist)\n} */\n\nfunc circulos(pen *Pen, dist float64) {\n\tpen.DrawCircle(dist)\n\n\tfor range 6 {\n\t\tpen.Left(60)\n\n\t\tpen.Up()\n        pen.Walk(dist)\n        pen.Down()\n\n\t\tcirculos(pen, dist * 0.5)\n\n\t\tpen.Up()\n        pen.Walk(dist)\n        pen.Down()\n\t}\n}\nfunc main() {\n\tpen := NewPen(2000, 2000)\n\tpen.SetRGB(0, 0, 0)\n\tpen.SetHeading(90)\n\tpen.SetPosition(1000, 1000)\n\tcirculos(pen, 600)\n\tpen.SavePNG(\"tree.png\")\n\tfmt.Println(\"PNG file created successfully.\")\n}\n",
