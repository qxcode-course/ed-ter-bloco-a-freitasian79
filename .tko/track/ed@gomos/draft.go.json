            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tvar Q int\n\tvar d string\n\n\tfmt.Scan(&Q)\n\n\tfmt.Scan(&d)\n\n\tx := make([]int, Q)\n\ty := make([]int, Q)\n\n\t// contagem dos gomos\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Scan(&x[i], &y[i])\n\t}\n\n\tfor i := Q - 1; i > 0; i-- {\n\t\tx[i], y[i] = x[i-1], y[i-1]\n\t}\n\n\t//movimento da cabe\u00e7a\n\n\tswitch d {\n\tcase \"L\":\n\t\tx[0]--\n\tcase \"R\":\n\t\tx[0]++\n\tcase \"U\":\n\t\ty[0]--\n\tcase \"D\":\n\t\ty[0]++\n\t}\n\n\tfor i := 0; i < Q; i++ {\n\t\tfmt.Printf(\"%d %d\\n\", x[i], y[i])\n\t}\n}\n",
